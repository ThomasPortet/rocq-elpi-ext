
func pos_encode term -> int.
pos_encode {{xH}} 1.
pos_encode {{xO lp:X}} N :- pos_encode X N1, N is N1 * 2.
pos_encode {{xI lp:X}} N :- pos_encode X N1, N is N1 * 2 + 1.

func pos_decode int -> term.
pos_decode 1 {{xH}} :- !.
pos_decode N {{xO lp:X}} :- 0 is N mod 2, !,  N1 is N div 2,  pos_decode N1 X.
pos_decode N {{xI lp:X}} :- N1 is N div 2, pos_decode N1 X.

func z_encode term -> int.
z_encode {{Z0}} 0.
z_encode {{Zpos lp:P}} N :- pos_encode P N.
z_encode {{Zneg lp:P}} N :- pos_encode P N1, N is 0 - N1.

func z_decode int -> term.
z_decode 0 {{Z0}} :- !.
z_decode N {{Zpos lp:P}} :- N > 0 ,!, pos_decode N P.
z_decode N {{Zneg lp:P}} :-  N1 is 0 - N, pos_decode N1 P.

func p_inj int, polyT -> polyT.
p_inj 0 P P :- !.
p_inj N (pcst R) (pcst R) :- N > 0, !.
p_inj N (var V) (var V') :- N > 0, !, V' is V + N.
p_inj N (add P Q) (add P' Q') :- N > 0, !, 
  p_inj N P P', 
  p_inj N Q Q'.
p_inj N (mul P Q) (mul P' Q') :- N > 0, !, 
  p_inj N P P', 
  p_inj N Q Q'.

func pow_x int -> polyT.
pow_x 0 (pcst (rat 1 1)) :- !.
pow_x N (var 1) :- N = 1, !.
pow_x N (mul X Y) :- N > 1, !, 
  N1 is N - 1, 
  pow_x N1 Y,
  X = (var 1).

func pol_encode term -> polyT.
pol_encode {{Pc lp:C}} (pcst (rat C1 1)) :- !,
  z_encode C C1.

pol_encode {{Pinj lp:J lp:Q}} P' :- !,
  pos_encode J J',
  pol_encode Q P,
  p_inj J' P P'.

pol_encode {{PX lp:P lp:I lp:Q}} (add PXpart Qpart) :- !,
  pol_encode P EncodedP,
  pos_encode I I',
  pow_x I' PowerX,
  PXpart = (mul EncodedP PowerX),
  pol_encode Q EncodedQ,
  p_inj 1 EncodedQ Qpart.

func pe_decode polyT -> term.
pe_decode (pcst (rat 0 _)) {{PEO}} :- !.
pe_decode (pcst (rat N N)) {{PEI}} :- !.
pe_decode (pcst (rat Num 1)) {{@PEc Z lp:Num1 }} :- !,
  z_decode Num Num1.
pe_decode (var Y) {{@PEX Z lp:X}} :- !,
 pos_decode Y X.
pe_decode (add P1 P2) X1 :- 
   pe_decode P2 {{PEO}}, !, pe_decode P1 X1.
pe_decode (add P1 P2) X2 :-
  pe_decode P1 {{PEO}}, !, pe_decode P2 X2.
pe_decode (add P1 (mul (pcst (rat (-1) 1)) P2)) {{PEsub lp:X1 lp:X2}} :- !,
  pe_decode P1 X1, pe_decode P2 X2.
pe_decode (add P1 P2) {{@PEadd Z lp:X1 lp:X2}} :- !,
  pe_decode P1 X1, pe_decode P2 X2 .
pe_decode (mul (pcst (rat 1 1)) X) Y :- !,
  pe_decode X Y.
pe_decode (mul X (pcst (rat 1 1))) Y :- !,
  pe_decode X Y.
pe_decode (mul X (pcst (rat (-1) 1))) {{PEopp lp:Y}} :- !,
  pe_decode X Y.
pe_decode (mul (pcst (rat (-1) 1)) X) {{PEopp lp:Y}} :- !,
  pe_decode X Y.
pe_decode (mul X Y) {{@PEpow Z lp:Z (Npos lp:N1)}}:-
  pe_decode Y {{@PEpow Z lp:Z (Npos lp:N)}},
  pos_encode N N',
  N'1 is N' + 1,
  pos_decode N'1 N1,
  pe_decode X Z,!.
pe_decode (mul Y X) {{@PEpow Z lp:Z (Npos lp:N1)}}:-
  pe_decode Y {{@PEpow Z lp:Z (Npos lp:N)}},
  pos_encode N N',
  N'1 is N' + 1,
  pos_decode N'1 N1,
  pe_decode X Z,!.
pe_decode (mul P1 P2) {{PEmul lp:X1 lp:X2}} :- !,
  pe_decode P1 X1, pe_decode P2 X2.
pe_decode P1 {{@PEpow Z lp:X (Npos 1%positive)}} :-
 pe_decode P1 X.

func gcd_int int, int -> int.
gcd_int A B G :-
A < 0 ,!, 
gcd_int (0 - A) B G.
gcd_int A B G :-
B < 0,!, 
gcd_int A (0 - B) G.
gcd_int 0 0 1 :-!.
gcd_int A 0 A :-!.
gcd_int 0 B B :-!.
gcd_int A B G :-
  C is A mod B,
  gcd_int B C G.


func lcm_int int, int -> int.
lcm_int A B C :-
  gcd_int A B G,
  C is ((A * B) div G).

func collect_glob_lcm term, int -> int.
collect_glob_lcm {{FEO}} I I :- !.
collect_glob_lcm {{FEI}} I I :- !.
collect_glob_lcm {{@FEadd Z lp:X1 lp:X2}} L LCM :- !,
  collect_glob_lcm X1 L L', collect_glob_lcm X2 L' LCM.
collect_glob_lcm {{@FEmul Z lp:X1 lp:X2}} L LCM :- !,
  collect_glob_lcm X1 L L', collect_glob_lcm X2 L' LCM.
collect_glob_lcm {{@FEc Z lp:C}} L LCM :-
  z_encode C I, !,
  lcm_int I L LCM.
collect_glob_lcm _ L L.

func collect_glob_lcm_poly polyT, int -> int.
collect_glob_lcm_poly (pcst (rat 0 _)) I I :- !.
collect_glob_lcm_poly (pcst (rat N N)) I I :- !.
collect_glob_lcm_poly (pcst (rat _ 1)) I I :- !.
collect_glob_lcm_poly (pcst (rat _ I)) L LCM :- !,
  lcm_int I L LCM.
collect_glob_lcm_poly (mul P1 P2) L LCM :- !,
  collect_glob_lcm_poly P1 L L', collect_glob_lcm_poly P2 L' LCM.
collect_glob_lcm_poly (add P1 P2) L LCM :- !,
  collect_glob_lcm_poly P1 L L', collect_glob_lcm_poly P2 L' LCM.
collect_glob_lcm_poly _ L L.

func multiply_lcm_poly polyT, int -> polyT.
multiply_lcm_poly (pcst (rat 0 _)) _ (pcst (rat 0 1)) :- !.
multiply_lcm_poly (pcst (rat N N)) L (pcst (rat L 1)) :- !.
multiply_lcm_poly (pcst (rat Num 1)) L (pcst (rat Num' 1))  :- !,
  Num' is Num * L.

multiply_lcm_poly (pcst (rat Num Denom)) L (pcst (rat N' 1)) :- !,
  M is L div Denom,
  N' is Num * M.

multiply_lcm_poly (mul P1 P2) L (mul P1' P2') :- !,
  multiply_lcm_poly P1 L P1', multiply_lcm_poly P2 L P2'.

multiply_lcm_poly (add P1 P2) L (add P1' P2') :- !,
  multiply_lcm_poly P1 L P1', multiply_lcm_poly P2 L P2'.

multiply_lcm_poly P _ P.

func multiply_if_gt_one polyT, int -> polyT.
multiply_if_gt_one P N P1 :-
  N > 1, !,
  multiply_lcm_poly P N P1.
multiply_if_gt_one P _ P.

% encoding func, decoding func, N , D -> N', D', Gcd, LCM
func gcd_and_factors (func term -> polyT), (func polyT -> term), term, term -> term, term, term, term.
gcd_and_factors Encoder Decoder N D Ne De Gcd' LCMZ :-
  Encoder N Nx,
  Encoder D Dx,
  gcd_poly Nx Dx Gcd Ne' De',
  collect_glob_lcm_poly Ne' 1 LCMN,
  collect_glob_lcm_poly De' LCMN LCMD,
  collect_glob_lcm_poly Gcd LCMD LCM,
  multiply_if_gt_one Ne' LCM N',
  multiply_if_gt_one De' LCM D',
  multiply_if_gt_one Gcd LCM G',
  Decoder N' Ne,
  Decoder D' De,
  Decoder G' Gcd',
  LCM2 is LCM * LCM,
  z_decode LCM2 LCMZ.
